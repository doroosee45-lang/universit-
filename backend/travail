    doc.moveDown();

    // Tableau des notes
    doc.font('Helvetica-Bold').fontSize(11).text('Détail des notes');
    doc.moveDown(0.5);

    // En-têtes colonnes
    const colX = { ue: 50, title: 90, coeff: 330, credits: 380, avg: 430, mention: 470 };
    doc.fontSize(9).font('Helvetica-Bold');
